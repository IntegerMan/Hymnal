<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Aliases -->
    <SolidColorBrush x:Key="SynthwaveBackgroundBrush" Color="#0D0B14" />

    <!-- Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="#0D0B14" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#141020" />
    <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="#1C1729" />
    <SolidColorBrush x:Key="SurfaceHighBrush" Color="#241F35" />

    <!-- Border Colors -->
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#2D2540" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#3D3560" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#EDE8F5" />
    <SolidColorBrush x:Key="OnSurfaceDimBrush" Color="#9589B0" />
    <SolidColorBrush x:Key="OnSurfaceMutedBrush" Color="#574E70" />

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="SynthwavePurpleBrush" Color="#9D4EDD" />
    <SolidColorBrush x:Key="PrimaryBrightBrush" Color="#B469F0" />
    <SolidColorBrush x:Key="PinkBrush" Color="#E91E8C" />
    <SolidColorBrush x:Key="YellowBrush" Color="#F5C842" />
    <SolidColorBrush x:Key="OrangeBrush" Color="#FF6B35" />
    <SolidColorBrush x:Key="CyanBrush" Color="#38BDF8" />

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF4D4F" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#22D3A0" />
    <SolidColorBrush x:Key="InfoBrush" Color="#38BDF8" />

    <!-- Font Families -->
    <FontFamily x:Key="InterFont">avares://Hymnal/Assets/Fonts#Inter</FontFamily>
    <FontFamily x:Key="EditorFont">avares://Hymnal/Assets/Fonts#JetBrains Mono</FontFamily>

</ResourceDictionary>
