<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:avedit="using:AvaloniaEdit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Hymnal.Views.EditorView"
             x:DataType="vm:EditorViewModel"
             Background="Transparent">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Conflict strip: visible when an external file change conflicts with dirty buffer -->
        <Border Grid.Row="0"
                IsVisible="{Binding HasConflict}"
                Background="{DynamicResource SurfaceHighBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{Binding ConflictMessage}"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="600" />
                <Button Content="Keep my edits"
                        Command="{Binding KeepLocalCommand}"
                        Padding="10,4"
                        CornerRadius="4" />
                <Button Content="Reload from disk"
                        Command="{Binding AcceptExternalCommand}"
                        Padding="10,4"
                        CornerRadius="4" />
            </StackPanel>
        </Border>

        <!-- Book.txt warning banner -->
        <Border Grid.Row="1"
                IsVisible="{Binding ShowBookTxtWarning}"
                Background="#1A9D4EDD"
                BorderBrush="{DynamicResource SynthwavePurpleBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,7">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Path Data="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      Stroke="{DynamicResource SynthwavePurpleBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round"
                      Width="18" Height="18"
                      Stretch="Uniform"
                      VerticalAlignment="Center" />
                <TextBlock Text="Editing Book.txt — this file defines the chapter list. Save (Ctrl+S) to refresh the sidebar."
                           Foreground="{DynamicResource OnSurfaceDimBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <avedit:TextEditor x:Name="PART_Editor"
                               IsVisible="{Binding ShowEditor}"
                               FontFamily="{DynamicResource EditorFont}"
                               FontSize="14"
                               WordWrap="True"
                               ShowLineNumbers="False"
                               Background="Transparent"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               HorizontalScrollBarVisibility="Disabled"
                               VerticalScrollBarVisibility="Auto"
                               Padding="16,12" />

            <Border IsVisible="{Binding ShowWorkspacePrompt}"
                    Background="{DynamicResource SurfaceBaseBrush}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            MaxWidth="420">
                    <TextBlock Text="Open a workspace"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Use File > Open Workspace or the sidebar button to load a manuscript."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowNoChapterPrompt}"
                    Background="{DynamicResource SurfaceBaseBrush}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            MaxWidth="420">
                    <TextBlock Text="No chapter open"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Select a chapter in the sidebar to load its Markua content here."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowNoResearchDocPrompt}"
                    Background="{DynamicResource SurfaceBaseBrush}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            MaxWidth="420">
                    <TextBlock Text="No research doc open"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Select a file in the DOCS sidebar, or create or import one to begin."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowMissingChapterPrompt}"
                    Background="{DynamicResource SurfaceBaseBrush}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12"
                            MaxWidth="460">
                    <Path Data="M12 2L2 20h20L12 2zm0 5.5L18.25 18H5.75L12 7.5zm-1 4.5h2v4h-2zm0 5.2h2v2h-2z"
                          Fill="{DynamicResource OrangeBrush}"
                          Width="40" Height="40"
                          Stretch="Uniform"
                          HorizontalAlignment="Center" />
                    <TextBlock Text="Chapter not found on disk"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="{Binding MissingChapterMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                </StackPanel>
            </Border>
        </Grid>

    </Grid>

</UserControl>
