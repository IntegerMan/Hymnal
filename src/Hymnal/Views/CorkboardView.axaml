<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:conv="using:Hymnal.Views.Converters"
             x:Class="Hymnal.Views.CorkboardView"
             x:Name="Root"
             x:DataType="vm:CorkboardViewModel"
             Background="#0B0820"
             Focusable="True"
             KeyDown="Root_KeyDown">

    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.cork-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>
        <Style Selector="Button.cork-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Button.cork-card.selected">
            <Setter Property="Background" Value="#191233" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Border.cork-divider">
            <Setter Property="Background" Value="#15102A" />
            <Setter Property="BorderBrush" Value="#2D1B5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style Selector="Border.cork-hint">
            <Setter Property="Background" Value="#100D1F" />
            <Setter Property="BorderBrush" Value="#3A245D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="48,*">
        <Border Grid.Row="0"
                Background="#120932"
                BorderBrush="#2D1B5E"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  Margin="16,0">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="▤"
                               FontSize="16"
                               Foreground="#9D4EDD"
                               VerticalAlignment="Center"
                               Margin="0,0,0,1" />
                    <TextBlock Text="PLAN BOARD"
                               FontSize="10"
                               FontWeight="SemiBold"
                               LetterSpacing="2"
                               Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="Click a chapter card to open it in Write mode"
                           FontSize="10"
                           Foreground="#94A3B8"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyBoardState"
                       Text="No chapters in this board yet. Open Book.txt or add chapters to see Plan mode cards."
                       IsVisible="{Binding !HasItems}"
                       Margin="24"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource OnSurfaceMutedBrush}" />

            <ScrollViewer x:Name="BoardScroll"
                          IsVisible="{Binding HasItems}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#0B0820">
                <ItemsControl x:Name="BoardItems"
                              ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="16"
                                       Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>

    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:PartDividerItemViewModel">
            <Border Classes="cork-divider"
                    Width="{Binding Bounds.Width, ElementName=Root}">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Section divider"
                               FontSize="10"
                               Foreground="#94A3B8" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="vm:EmptyPartHintItemViewModel">
            <Border Classes="cork-hint"
                    Width="{Binding Bounds.Width, ElementName=Root}">
                <TextBlock Text="{Binding HintText}"
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="#94A3B8" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="vm:ChapterCardItemViewModel">
            <Button Classes="cork-card"
                    Classes.selected="{Binding Card.IsSelected}"
                    Command="{Binding DataContext.OpenCardCommand, ElementName=Root}"
                    CommandParameter="{Binding}"
                    PointerPressed="Card_PointerPressed"
                    PointerMoved="Card_PointerMoved"
                    PointerReleased="Card_PointerReleased"
                    Loaded="Card_Loaded">

                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open"
                                  Command="{Binding DataContext.OpenCardCommand, ElementName=Root}"
                                  CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Rename…"
                                  Click="RenameCard_Click" />
                        <MenuItem Header="New Chapter…"
                                  Click="NewChapter_Click" />
                        <MenuItem Header="Include Existing Chapter…"
                                  Click="IncludeExistingChapter_Click" />
                        <Separator />
                        <MenuItem Header="Remove from Book"
                                  Click="RemoveFromBook_Click" />
                        <MenuItem Header="Delete Chapter File…"
                                  Click="DeleteChapter_Click" />
                    </ContextMenu>
                </Button.ContextMenu>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <StackPanel Grid.Row="0"
                                Spacing="2">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding RelativePath}"
                                   FontSize="10"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="12">
                        <StackPanel Grid.Column="0"
                                    Spacing="2">
                            <TextBlock Text="Status"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.StatusDisplay}"
                                       FontSize="11"
                                       Foreground="{Binding Card.Status, Converter={StaticResource StatusToBrushConverter}}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <TextBlock Text="Words"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.WordCountDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Spacing="2">
                            <TextBlock Text="Target"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.TargetDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="72,*,84"
                          ColumnSpacing="8"
                          VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="Progress"
                                   FontSize="9"
                                   LetterSpacing="1.5"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1"
                                     Value="{Binding Card.ProximityFill}"
                                     Minimum="0"
                                     Maximum="1"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     Background="{DynamicResource SurfaceHighBrush}"
                                     Foreground="{DynamicResource SynthwavePurpleBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Card.ProximityFill, StringFormat={}{0:P0}}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Phase start"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.PhaseStartDateDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Phase end"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.PhaseEndDateDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Text="{Binding Card.MissingStateDisplay}"
                               FontSize="10"
                               Foreground="{DynamicResource OrangeBrush}"
                               IsVisible="{Binding Card.IsMissing}" />
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.DataTemplates>

</UserControl>
