<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:conv="using:Hymnal.Views.Converters"
             x:Class="Hymnal.Views.CorkboardView"
             x:Name="Root"
             x:DataType="vm:CorkboardViewModel"
             x:CompileBindings="False"
             Background="#0B0820"
             Focusable="True"
             KeyDown="Root_KeyDown">

    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <conv:CardDisplaySizeEqualsConverter x:Key="CardDisplaySizeEqualsConverter" />
        <conv:CardDisplaySizeNotEqualsConverter x:Key="CardDisplaySizeNotEqualsConverter" />
        <conv:CardDisplaySizeAtLeastConverter x:Key="CardDisplaySizeAtLeastConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.cork-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>
        <Style Selector="Button.cork-card.card-size-medium">
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Button.cork-card.card-size-tiny">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MaxWidth" Value="220" />
            <Setter Property="Padding" Value="8,6,8,8" />
        </Style>
        <Style Selector="Button.cork-card.card-size-list">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="Infinity" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.cork-card.card-size-medium Grid.cork-card-body">
            <Setter Property="RowSpacing" Value="6" />
        </Style>
        <Style Selector="Button.cork-card.card-size-tiny Grid.cork-card-body">
            <Setter Property="RowSpacing" Value="4" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>
        <Style Selector="Button.cork-card TextBlock.cork-card-title">
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style Selector="Button.cork-card.card-size-medium TextBlock.cork-card-title">
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.cork-card.card-size-tiny TextBlock.cork-card-title">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.cork-card.cork-card-missing">
            <Setter Property="BorderBrush" Value="{DynamicResource OrangeBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
        </Style>
        <Style Selector="Button.cork-card.card-size-tiny TextBlock.cork-card-missing-text">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="Button.cork-card.card-size-list TextBlock.cork-card-missing-text">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="Border.cork-card-status-stripe">
            <Setter Property="Width" Value="3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="2,0,0,2" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Border.cork-card-missing-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource OrangeBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,2,2,0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Button.cork-card.card-size-list Border.cork-card-missing-dot">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="Ellipse.cork-card-status-dot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.cork-card-list-missing">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource OrangeBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="16" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.cork-part-header.card-size-list-part">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="Panel.cork-card-host.card-size-list-host">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.cork-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Button.cork-card.selected">
            <Setter Property="Background" Value="#191233" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="ToggleButton.cork-size-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#2D1B5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#94A3B8" />
        </Style>
        <Style Selector="ToggleButton.cork-size-toggle:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="ToggleButton.cork-size-toggle:checked">
            <Setter Property="Background" Value="#191233" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Button.cork-part-header">
            <Setter Property="Background" Value="#15102A" />
            <Setter Property="BorderBrush" Value="#2D1B5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="Button.cork-part-header.part-follow">
            <Setter Property="Margin" Value="0,16,0,10" />
        </Style>
        <Style Selector="Button.cork-part-header:pointerover">
            <Setter Property="Background" Value="#191233" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Button.cork-part-header:pointerover Border.cork-part-chevron-badge">
            <Setter Property="Background" Value="#3A245D" />
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="Border.cork-part-chevron-badge">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#221640" />
            <Setter Property="BorderBrush" Value="#4C2A85" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.cork-part-chevron">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#E9D5FF" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.cork-hint">
            <Setter Property="Background" Value="#100D1F" />
            <Setter Property="BorderBrush" Value="#3A245D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style Selector="Button.cork-excluded-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#64748B" />
            <Setter Property="BorderThickness" Value="1,1,1,1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="Button.cork-excluded-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
            <Setter Property="Background" Value="#12102A" />
            <Setter Property="Opacity" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="48,*">
        <Border Grid.Row="0"
                Background="#120932"
                BorderBrush="#2D1B5E"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  Margin="16,0">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="▤"
                               FontSize="16"
                               Foreground="#9D4EDD"
                               VerticalAlignment="Center"
                               Margin="0,0,0,1" />
                    <TextBlock Text="PLAN BOARD"
                               FontSize="10"
                               FontWeight="SemiBold"
                               LetterSpacing="2"
                               Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <ToggleButton Classes="cork-size-toggle"
                                  Content="Large"
                                  Command="{Binding SetCardSizeCommand}"
                                  CommandParameter="{x:Static vm:CardDisplaySize.Large}"
                                  IsChecked="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large, Mode=OneWay}" />
                    <ToggleButton Classes="cork-size-toggle"
                                  Content="Medium"
                                  Command="{Binding SetCardSizeCommand}"
                                  CommandParameter="{x:Static vm:CardDisplaySize.Medium}"
                                  IsChecked="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Medium, Mode=OneWay}" />
                    <ToggleButton Classes="cork-size-toggle"
                                  Content="Tiny"
                                  Command="{Binding SetCardSizeCommand}"
                                  CommandParameter="{x:Static vm:CardDisplaySize.Tiny}"
                                  IsChecked="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Tiny, Mode=OneWay}" />
                    <ToggleButton Classes="cork-size-toggle"
                                  Content="List"
                                  Command="{Binding SetCardSizeCommand}"
                                  CommandParameter="{x:Static vm:CardDisplaySize.List}"
                                  IsChecked="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List, Mode=OneWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <CheckBox Content="Show excluded"
                              IsChecked="{Binding ShowExcludedFiles, Mode=TwoWay}"
                              FontSize="10"
                              Foreground="#94A3B8" />
                    <Button x:Name="BoardAddButton"
                            Content="+"
                            Padding="10,4"
                            FontSize="12"
                            FontWeight="Bold"
                            Background="Transparent"
                            BorderBrush="#2D1B5E"
                            BorderThickness="1"
                            CornerRadius="6"
                            Foreground="#9D4EDD"
                            ToolTip.Tip="Add chapter or part"
                            Click="BoardAddButton_Click" />
                    <TextBlock Text="Double-click a card to open in Write mode"
                               FontSize="10"
                               Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyBoardState"
                       Text="No chapters in this board yet. Open Book.txt or add chapters to see Plan mode cards."
                       IsVisible="{Binding !HasItems}"
                       Margin="24"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource OnSurfaceMutedBrush}" />

            <ScrollViewer x:Name="BoardScroll"
                          IsVisible="{Binding HasItems}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#0B0820">
                <Grid>
                    <ItemsControl x:Name="BoardItems"
                                  ItemsSource="{Binding Items}"
                                  IsVisible="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeNotEqualsConverter}, ConverterParameter=List}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="16"
                                           Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <ItemsControl x:Name="BoardItemsList"
                                  ItemsSource="{Binding Items}"
                                  IsVisible="{Binding CardDisplaySize, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Margin="16,12"
                                            Spacing="0" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>

    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:PartDividerItemViewModel">
            <Grid ColumnDefinitions="*,Auto"
                  Width="{Binding Bounds.Width, ElementName=Root}"
                  Margin="0,0,0,10">
                <Button Grid.Column="0"
                        Classes="cork-part-header"
                        Classes.part-follow="{Binding !IsFirstPart}"
                        Classes.card-size-list-part="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}"
                        Margin="0"
                        Focusable="False"
                        Command="{Binding DataContext.TogglePartExpandedCommand, ElementName=Root}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="Click to show or hide chapters in this part">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Classes="cork-part-chevron-badge">
                            <TextBlock Classes="cork-part-chevron"
                                       Text="{Binding ChevronGlyph}" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="Left" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ChapterCountDisplay}"
                                   FontSize="10"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Button Grid.Column="1"
                        Content="+"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        MinWidth="32"
                        MinHeight="40"
                        FontSize="12"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#2D1B5E"
                        BorderThickness="1"
                        CornerRadius="6"
                        Foreground="#9D4EDD"
                        ToolTip.Tip="Add chapter to this part"
                        Tag="{Binding}"
                        Click="PartAddButton_Click" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="vm:EmptyPartHintItemViewModel">
            <Border Classes="cork-hint"
                    Width="{Binding Bounds.Width, ElementName=Root}"
                    IsVisible="{Binding IsVisibleOnBoard}">
                <TextBlock Text="{Binding HintText}"
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="#94A3B8" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="vm:InlineCreateItemViewModel">
            <Panel Classes="cork-card-host"
                   Classes.card-size-list-host="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}"
                   IsVisible="{Binding IsVisibleOnBoard}">
                <Border Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource SynthwavePurpleBrush}"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="14,12"
                        MinWidth="280"
                        MaxWidth="520"
                        HorizontalAlignment="Left"
                        Margin="0,0,12,12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="NEW CHAPTER"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.5"
                                   Foreground="{DynamicResource SynthwavePurpleBrush}" />
                        <TextBox Text="{Binding TitleText, Mode=TwoWay}"
                                 PlaceholderText="Chapter title..."
                                 Background="Transparent"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="{DynamicResource SynthwavePurpleBrush}"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 Padding="0,4"
                                 Loaded="InlineCreate_Loaded"
                                 KeyDown="InlineCreate_KeyDown" />
                        <TextBlock Text="Enter to create  ·  Escape to cancel"
                                   FontSize="9"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}" />
                    </StackPanel>
                </Border>
            </Panel>
        </DataTemplate>

        <DataTemplate DataType="vm:ChapterCardItemViewModel">
            <Panel Classes="cork-card-host"
                   Classes.card-size-list-host="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}">
                <!-- Insertion-line indicators: appear in the gap before or after this card during drag-over -->
                <Border Name="InsertBefore"
                        Width="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Margin="-8,4,0,16"
                        Background="{DynamicResource SynthwavePurpleBrush}"
                        CornerRadius="2"
                        IsVisible="False"
                        IsHitTestVisible="False" />
                <Border Name="InsertAfter"
                        Width="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Margin="0,4,4,16"
                        Background="{DynamicResource SynthwavePurpleBrush}"
                        CornerRadius="2"
                        IsVisible="False"
                        IsHitTestVisible="False" />
                <Button Classes="cork-card"
                    Classes.selected="{Binding Card.IsSelected}"
                    Classes.cork-card-missing="{Binding Card.IsMissing}"
                    Classes.card-size-large="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large}"
                    Classes.card-size-medium="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Medium}"
                    Classes.card-size-tiny="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Tiny}"
                    Classes.card-size-list="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}"
                    IsVisible="{Binding IsVisibleOnBoard}"
                    DoubleTapped="Card_DoubleTapped"
                    Loaded="Card_Loaded">

                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open"
                                  Command="{Binding DataContext.OpenCardCommand, ElementName=Root}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Mark complete"
                                  Command="{Binding Card.Chapter.CompletePhaseCommand}"
                                  IsVisible="{Binding Card.CanCompletePhase}" />
                        <Separator />
                        <MenuItem Header="Rename…"
                                  Click="RenameCard_Click" />
                        <MenuItem Header="New Chapter…"
                                  Click="NewChapter_Click" />
                        <MenuItem Header="Include Existing Chapter…"
                                  Click="IncludeExistingChapter_Click" />
                        <Separator />
                        <MenuItem Header="Remove from Book"
                                  Click="RemoveFromBook_Click" />
                        <MenuItem Header="Delete Chapter File…"
                                  Click="DeleteChapter_Click" />
                    </ContextMenu>
                </Button.ContextMenu>

                <Grid>
                    <Border Classes="cork-card-status-stripe"
                            Background="{Binding Card.Status, Converter={StaticResource StatusToBrushConverter}}"
                            IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Tiny}" />
                    <Border Classes="cork-card-missing-dot"
                            IsVisible="{Binding Card.IsMissing}" />

                    <Grid Classes="cork-card-body"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeNotEqualsConverter}, ConverterParameter=List}">
                    <TextBlock Grid.Row="0"
                               Classes="cork-card-title"
                               Text="{Binding Title}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="1"
                               Text="{Binding RelativePath}"
                               FontSize="10"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"
                               IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large}" />

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="12"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large}">
                        <StackPanel Grid.Column="0"
                                    Spacing="2">
                            <TextBlock Text="Status"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.StatusDisplay}"
                                       FontSize="11"
                                       Foreground="{Binding Card.Status, Converter={StaticResource StatusToBrushConverter}}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <TextBlock Text="Words"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.WordCountDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Spacing="2">
                            <TextBlock Text="Target"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.TargetDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Medium}">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Card.StatusDisplay}"
                                   FontSize="11"
                                   Foreground="{Binding Card.Status, Converter={StaticResource StatusToBrushConverter}}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Card.WordCountDisplay}"
                                   FontSize="11"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="4"
                          ColumnDefinitions="72,*,84"
                          ColumnSpacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large}">
                        <TextBlock Grid.Column="0"
                                   Text="Progress"
                                   FontSize="9"
                                   LetterSpacing="1.5"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1"
                                     Value="{Binding Card.ProximityFill}"
                                     Minimum="0"
                                     Maximum="1"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     Background="{DynamicResource SurfaceHighBrush}"
                                     Foreground="{DynamicResource SynthwavePurpleBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Card.ProximityFill, StringFormat={}{0:P0}}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="4"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Medium}">
                        <ProgressBar Grid.Column="0"
                                     Value="{Binding Card.ProximityFill}"
                                     Minimum="0"
                                     Maximum="1"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     Background="{DynamicResource SurfaceHighBrush}"
                                     Foreground="{DynamicResource SynthwavePurpleBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Card.ProximityFill, StringFormat={}{0:P0}}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="6"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Large}">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Phase start"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.PhaseStartDateDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Phase end"
                                       FontSize="9"
                                       LetterSpacing="1.5"
                                       Foreground="#94A3B8" />
                            <TextBlock Text="{Binding Card.PhaseEndDateDisplay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                    </Grid>

                    <ProgressBar Grid.Row="5"
                                 Value="{Binding Card.ProximityFill}"
                                 Minimum="0"
                                 Maximum="1"
                                 Height="3"
                                 VerticalAlignment="Center"
                                 Background="{DynamicResource SurfaceHighBrush}"
                                 Foreground="{DynamicResource SynthwavePurpleBrush}"
                                 IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=Tiny}" />

                    <TextBlock Grid.Row="7"
                               Classes="cork-card-missing-text"
                               Text="{Binding Card.MissingStateDisplay}"
                               FontSize="10"
                               Foreground="{DynamicResource OrangeBrush}"
                               IsVisible="{Binding Card.IsMissing}" />
                    </Grid>

                    <Grid Classes="cork-card-list-body"
                          ColumnDefinitions="Auto,*,60,50,16"
                          ColumnSpacing="10"
                          IsVisible="{Binding DataContext.CardDisplaySize, ElementName=Root, Converter={StaticResource CardDisplaySizeEqualsConverter}, ConverterParameter=List}">
                        <Ellipse Grid.Column="0"
                                 Classes="cork-card-status-dot"
                                 Fill="{Binding Card.Status, Converter={StaticResource StatusToBrushConverter}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <ProgressBar Grid.Column="2"
                                     Value="{Binding Card.ProximityFill}"
                                     Minimum="0"
                                     Maximum="1"
                                     Height="4"
                                     VerticalAlignment="Center"
                                     Background="{DynamicResource SurfaceHighBrush}"
                                     Foreground="{DynamicResource SynthwavePurpleBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Card.WordCountDisplay}"
                                   FontSize="11"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4"
                                   Classes="cork-card-list-missing"
                                   Text="!"
                                   ToolTip.Tip="Missing file"
                                   IsVisible="{Binding Card.IsMissing}" />
                    </Grid>
                </Grid>
                </Button>
            </Panel>
        </DataTemplate>

        <DataTemplate DataType="vm:ExcludedChapterCardItemViewModel">
            <Button Classes="cork-excluded-card"
                    IsVisible="{Binding IsVisibleOnBoard}"
                    Tag="{Binding}">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Include in Book"
                                  Click="IncludeExcludedCard_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ExcludedLabel}"
                                   FontSize="10"
                                   FontStyle="Italic"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding RelativePath}"
                               FontSize="10"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.DataTemplates>

</UserControl>
