<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:views="clr-namespace:Hymnal.Views"
             x:Class="Hymnal.Views.GanttView"
             x:DataType="vm:GanttViewModel"
             Background="#0B0820">

    <!-- Outer Panel lets the edit overlay layer on top of the Gantt grid -->
    <Panel>

        <Grid RowDefinitions="48,*">

            <!-- ── Header bar ─────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#120932"
                    BorderBrush="#2D1B5E"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <!-- Gantt icon (horizontal bars) -->
                        <Path Data="M3 6h18M3 10h12M3 14h15M3 18h9"
                              Stroke="#9D4EDD"
                              StrokeThickness="1.5"
                              StrokeLineCap="Round"
                              Width="16" Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center" />
                        <TextBlock Text="GANTT"
                                   Margin="10,0,0,0"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   LetterSpacing="2"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Legend -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"
                                Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#38BDF8" />
                            <TextBlock Text="Drafting"  FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#E91E8C" />
                            <TextBlock Text="Editing"   FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#F59E0B" />
                            <TextBlock Text="Polishing" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#34D399" />
                            <TextBlock Text="Done"      FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable canvas ─────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#0B0820">
                <views:GanttCanvas x:Name="Canvas"
                                   Rows="{Binding Rows}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Top" />
            </ScrollViewer>

        </Grid>

        <!-- ── Inline date-edit overlay ─────────────────────────────────────── -->
        <!--
             Visible when IsEditingDates = true.
             Floats in the top-right corner so it does not obscure the row label
             column. The panel is outside the ScrollViewer so it stays on screen
             regardless of scroll position.
        -->
        <Border IsVisible="{Binding IsEditingDates}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,56,16,0"
                Width="270"
                Background="#1C103C"
                BorderBrush="#3D2070"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                ZIndex="10">
            <StackPanel Spacing="6">

                <!-- Overlay title -->
                <TextBlock Text="EDIT PHASE DATES"
                           FontSize="9"
                           FontWeight="SemiBold"
                           LetterSpacing="2"
                           Foreground="#9D4EDD" />

                <!-- Chapter name -->
                <TextBlock Text="{Binding EditingRow.Title, FallbackValue=''}"
                           FontSize="12"
                           Foreground="#CBD5E1"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,4" />

                <!-- Date pickers -->
                <Grid ColumnDefinitions="50,*" RowDefinitions="Auto,Auto" RowSpacing="6">

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Start"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="#94A3B8" />
                    <CalendarDatePicker Grid.Row="0" Grid.Column="1"
                                        SelectedDate="{Binding EditStartDate}"
                                        FontSize="11"
                                        MinWidth="0" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="End"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="#94A3B8" />
                    <CalendarDatePicker Grid.Row="1" Grid.Column="1"
                                        SelectedDate="{Binding EditEndDate}"
                                        FontSize="11"
                                        MinWidth="0" />
                </Grid>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0">
                    <Button Content="Cancel"
                            Command="{Binding CancelEditCommand}"
                            FontSize="11"
                            Padding="12,4" />
                    <Button Content="Save"
                            Command="{Binding CommitEditCommand}"
                            FontSize="11"
                            Padding="12,4" />
                </StackPanel>

            </StackPanel>
        </Border>

    </Panel>

</UserControl>
