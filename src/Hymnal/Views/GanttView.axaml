<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:models="using:Hymnal.Core.Models"
             xmlns:conv="using:Hymnal.Views.Converters"
             xmlns:views="clr-namespace:Hymnal.Views"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="Hymnal.Views.GanttView"
             x:DataType="vm:GanttViewModel"
             Background="#0B0820">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+Shift+Enter" Command="{Binding CompleteSelectedRowCommand}" />
    </UserControl.KeyBindings>

    <UserControl.Styles>
        <!-- CalendarDatePicker embedded directly in cells (no edit-mode required) -->
        <Style Selector="CalendarDatePicker.gantt-date-cell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="PlaceholderText" Value="" />
        </Style>
        <Style Selector="CalendarDatePicker.gantt-date-cell /template/ TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!-- Hide the calendar dropdown button (its glyph font renders as "7") -->
        <Style Selector="CalendarDatePicker.gantt-date-cell /template/ Button#PART_Button">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="48,*">

        <Border Grid.Row="0"
                Background="#120932"
                BorderBrush="#2D1B5E"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="592,*">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0">
                    <Path Data="M3 6h18M3 10h12M3 14h15M3 18h9"
                          Stroke="#9D4EDD"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          Width="16" Height="16"
                          Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <TextBlock Text="TIMELINE"
                               Margin="10,0,0,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               LetterSpacing="2"
                               Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0"
                            Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#9589B0" />
                        <TextBlock Text="Outlining" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#38BDF8" />
                        <TextBlock Text="Drafting" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#9D4EDD" />
                        <TextBlock Text="Editing" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#F5C842" />
                        <TextBlock Text="Polishing" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="2" Background="#E91E8C" />
                        <TextBlock Text="Reviewing" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0B0820">
            <Grid ColumnDefinitions="592,6,*">
                <dg:DataGrid Grid.Column="0"
                             x:Name="ChapterGrid"
                             ItemsSource="{Binding Rows}"
                             SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                             KeyDown="ChapterGrid_KeyDown"
                             AutoGenerateColumns="False"
                             HeadersVisibility="Column"
                             GridLinesVisibility="None"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             CanUserResizeColumns="False"
                             CanUserReorderColumns="False"
                             CanUserSortColumns="False"
                             IsReadOnly="False"
                             SelectionMode="Single"
                             RowHeight="28"
                             ColumnHeaderHeight="36"
                             Background="#0F0828"
                             BorderBrush="#2D1B5E"
                             BorderThickness="0,0,1,0"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Top">

                    <dg:DataGrid.ContextMenu>
                        <ContextMenu Opening="ChapterGrid_ContextMenuOpening">
                            <MenuItem Header="View details..."
                                      Click="ViewDetails_Click" />
                            <Separator />
                            <MenuItem Header="Mark complete"
                                      Click="MarkComplete_Click" />
                        </ContextMenu>
                    </dg:DataGrid.ContextMenu>

                    <dg:DataGrid.Columns>
                        <dg:DataGridTemplateColumn Header="CHAPTER" Width="220" IsReadOnly="True">
                            <dg:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <Border Padding="8,0" Background="{Binding RowBackground}">
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding RowForeground}"
                                                   FontSize="11.5" />
                                    </Border>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellTemplate>
                        </dg:DataGridTemplateColumn>

                        <dg:DataGridTemplateColumn Header="STATUS" Width="100">
                            <dg:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <Border Padding="6,0" Background="{Binding RowBackground}">
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   Foreground="{Binding StatusForeground}"
                                                   VerticalAlignment="Center"
                                                   FontSize="10.5" />
                                    </Border>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellTemplate>
                            <dg:DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                              SelectedItem="{Binding EditableStatus, Mode=TwoWay}"
                                              FontSize="10.5"
                                              MinHeight="24"
                                              Height="24"
                                              Padding="6,0"
                                              VerticalAlignment="Center"
                                              IsEnabled="{Binding IsEditable}"
                                              DropDownClosed="InlineStatus_DropDownClosed">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:ChapterStatus">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <Border Width="8"
                                                            Height="8"
                                                            CornerRadius="2"
                                                            Background="{Binding Converter={x:Static conv:StatusToBrushConverter.Instance}}"
                                                            VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{Binding Converter={x:Static conv:StatusToBrushConverter.Instance}}"
                                                               VerticalAlignment="Center"
                                                               FontSize="10.5" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellEditingTemplate>
                        </dg:DataGridTemplateColumn>

                        <dg:DataGridTemplateColumn Header="START" Width="130" IsReadOnly="True">
                            <dg:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <Grid Background="{Binding RowBackground}">
                                        <CalendarDatePicker SelectedDate="{Binding EditableStartDate, Mode=TwoWay}"
                                                            Classes="gantt-date-cell"
                                                            IsEnabled="{Binding IsEditable}"
                                                            IsVisible="{Binding IsEditable}"
                                                            GotFocus="DatePicker_GotFocus"
                                                            SelectedDateChanged="InlineStart_SelectedDateChanged" />
                                        <TextBlock Text="{Binding StartDateDisplay}"
                                                   IsVisible="{Binding !IsEditable}"
                                                   Foreground="{Binding RowForeground}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0"
                                                   FontSize="10" />
                                    </Grid>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellTemplate>
                        </dg:DataGridTemplateColumn>

                        <dg:DataGridTemplateColumn Header="END" Width="130" IsReadOnly="True">
                            <dg:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <Grid Background="{Binding RowBackground}">
                                        <CalendarDatePicker SelectedDate="{Binding EditableEndDate, Mode=TwoWay}"
                                                            Classes="gantt-date-cell"
                                                            IsEnabled="{Binding IsEditable}"
                                                            IsVisible="{Binding IsEditable}"
                                                            GotFocus="DatePicker_GotFocus"
                                                            SelectedDateChanged="InlineEnd_SelectedDateChanged" />
                                        <TextBlock Text="{Binding EndDateDisplay}"
                                                   IsVisible="{Binding !IsEditable}"
                                                   Foreground="{Binding RowForeground}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0"
                                                   FontSize="10" />
                                    </Grid>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellTemplate>
                        </dg:DataGridTemplateColumn>

                        <dg:DataGridTemplateColumn Header="%" Width="58">
                            <dg:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <Border Padding="6,0" Background="{Binding RowBackground}">
                                        <TextBlock Text="{Binding ProgressDisplay}"
                                                   Foreground="{Binding RowForeground}"
                                                   VerticalAlignment="Center"
                                                   FontSize="10" />
                                    </Border>
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellTemplate>
                            <dg:DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate x:DataType="vm:GanttRowViewModel">
                                    <TextBox Text="{Binding EditableProgressPercent, Mode=TwoWay,
                                                   Converter={x:Static conv:NullableDoubleToStringConverter.Instance}}"
                                             FontSize="10"
                                             MinHeight="24"
                                             Height="24"
                                             Padding="6,0"
                                             VerticalContentAlignment="Center"
                                             IsEnabled="{Binding IsEditable}"
                                             HorizontalContentAlignment="Right"
                                             KeyUp="InlineProgress_KeyUp"
                                             LostFocus="InlineProgress_LostFocus" />
                                </DataTemplate>
                            </dg:DataGridTemplateColumn.CellEditingTemplate>
                        </dg:DataGridTemplateColumn>
                    </dg:DataGrid.Columns>
                </dg:DataGrid>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#2D1B5E"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True" />

                <ScrollViewer Grid.Column="2"
                              x:Name="TimelineHorizontalScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Background="#0B0820">
                    <views:GanttCanvas x:Name="TimelineCanvas"
                                       Rows="{Binding Rows}"
                                       ShowTable="False"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Top" />
                </ScrollViewer>
            </Grid>
        </ScrollViewer>

    </Grid>

</UserControl>
