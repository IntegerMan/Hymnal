<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             x:Class="Hymnal.Views.NotesView"
             x:DataType="vm:NotesViewModel"
             Background="{DynamicResource SurfaceElevatedBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <TextBlock Text="{Binding ChapterTitle, FallbackValue='Notes'}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- Empty state: shown when no chapter is active -->
        <TextBlock Grid.Row="1"
                   Text="Open a chapter to start taking notes."
                   IsVisible="{Binding ChapterTitle, Converter={x:Static ObjectConverters.IsNull}}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontSize="12"
                   Margin="16" />

        <!-- Notes text area -->
        <TextBox Grid.Row="1"
                 Text="{Binding Text, Mode=TwoWay}"
                 IsVisible="{Binding ChapterTitle, Converter={x:Static ObjectConverters.IsNotNull}}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="{DynamicResource SurfaceBaseBrush}"
                 Foreground="{DynamicResource OnSurfaceBrush}"
                 BorderThickness="0"
                 Padding="10"
                 FontSize="13"
                 FontFamily="{DynamicResource InterFont}"
                 VerticalAlignment="Stretch"
                 CaretBrush="{DynamicResource SynthwavePurpleBrush}"
                 VerticalContentAlignment="Top" />

    </Grid>

</UserControl>
