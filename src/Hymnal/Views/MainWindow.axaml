<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Hymnal.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="Hymnal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Hymnal"
        Width="1280" Height="800"
        Background="{StaticResource SurfaceBaseBrush}"
        FontFamily="{DynamicResource InterFont}"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Synthwave accent top bar — confirms theme is live -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SynthwavePurpleBrush}"
                Height="2" />

        <!-- Placeholder shell content — S02 will replace this -->
        <TextBlock Text="{Binding Title}"
                   Foreground="{StaticResource OnSurfaceBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="24" />
    </DockPanel>

</Window>
