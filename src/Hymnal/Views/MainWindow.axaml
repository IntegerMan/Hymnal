<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Hymnal.ViewModels"
        xmlns:views="clr-namespace:Hymnal.Views"
        xmlns:aiviews="using:Hymnal.Views.Ai"
        xmlns:conv="using:Hymnal.Views.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="Hymnal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        Width="1280" Height="800"
        Background="#0B0820"
        FontFamily="{DynamicResource InterFont}"
        TransparencyLevelHint="None">

    <Window.Resources>
        <conv:ActiveIconBrushConverter x:Key="ActiveIconBrushConverter" />
        <conv:ShellModeEqualsConverter x:Key="ShellModeEqualsConverter" />
        <conv:BoolNotConverter x:Key="BoolNotConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- nav-icon: borderless icon button used in collapsed rail and expanded pane headers -->
        <Style Selector="Button.nav-icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.nav-icon:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}" />
        </Style>
        <Style Selector="Button.nav-icon:pressed">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
        </Style>

        <!-- nav-mode: underline text tab used in the top navigation bar -->
        <Style Selector="ToggleButton.nav-mode">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDimBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Indicator sits 3 px below the label text, the pair is vertically
                         centred in the button, so the line never drifts when the header is fixed height. -->
                    <Border Background="Transparent"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                            <Border x:Name="ActiveIndicator"
                                    Height="2"
                                    Background="Transparent"
                                    CornerRadius="1,1,0,0" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.nav-mode:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
        </Style>
        <Style Selector="ToggleButton.nav-mode:checked">
            <Setter Property="Foreground" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="ToggleButton.nav-mode:checked /template/ Border#ActiveIndicator">
            <Setter Property="Background" Value="{DynamicResource SynthwavePurpleBrush}" />
        </Style>
        <Style Selector="ToggleButton.nav-mode:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+B" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding ToggleAiChatCommand}" />
        <KeyBinding Gesture="F1" Command="{Binding ShowAboutCommand}" />
        <KeyBinding Gesture="F3" Command="{Binding ChapterInfoViewModel.ToggleCommand}" />
        <KeyBinding Gesture="F4" Command="{Binding NotesViewModel.ToggleCommand}" />
        <KeyBinding Gesture="F5" Command="{Binding ToggleGanttCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="48,Auto,*,Auto">

        <!-- Row 0: Menu bar + mode tabs in a single row -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: application menu -->
                <Menu Grid.Column="0"
                      Background="Transparent"
                      Foreground="{DynamicResource OnSurfaceBrush}"
                      Padding="4,2"
                      VerticalAlignment="Center">
                    <MenuItem Header="_File" Foreground="{DynamicResource OnSurfaceBrush}">
                        <MenuItem Header="_Open Workspace…"
                                  Command="{Binding WorkspaceViewModel.OpenWorkspaceCommand}" />
                        <MenuItem Header="_Close Workspace"
                                  Command="{Binding WorkspaceViewModel.CloseWorkspaceCommand}" />
                        <Separator />
                        <MenuItem Header="_Save"
                                  Command="{Binding EditorViewModel.SaveCommand}"
                                  InputGesture="Ctrl+S" />
                        <Separator />
                        <MenuItem Header="E_xit"
                                  Command="{Binding ExitCommand}" />
                    </MenuItem>
                    <MenuItem Header="_View" Foreground="{DynamicResource OnSurfaceBrush}">
                        <MenuItem Header="Toggle _Sidebar"
                                  Command="{Binding ToggleSidebarCommand}"
                                  InputGesture="Ctrl+B" />
                        <MenuItem Header="Toggle _Chapter Info"
                                  Command="{Binding ChapterInfoViewModel.ToggleCommand}"
                                  InputGesture="F3" />
                        <MenuItem Header="Toggle _Notes"
                                  Command="{Binding NotesViewModel.ToggleCommand}"
                                  InputGesture="F4" />
                        <MenuItem Header="Toggle _Manage View"
                                  Command="{Binding ToggleGanttCommand}"
                                  InputGesture="F5" />
                        <Separator />
                        <MenuItem Header="_Reset Write Layout"
                                  Command="{Binding ResetWriteLayoutCommand}" />
                    </MenuItem>
                    <MenuItem Header="_Help" Foreground="{DynamicResource OnSurfaceBrush}">
                        <MenuItem Header="_About Hymnal"
                                  Command="{Binding ShowAboutCommand}"
                                  InputGesture="F1" />
                    </MenuItem>
                </Menu>

                <!-- Centre: mode tabs — RESEARCH / PLAN / WRITE / MANAGE / EDIT -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="0">
                    <ToggleButton Classes="nav-mode"
                                  Content="RESEARCH"
                                  Command="{Binding SelectResearchCommand}"
                                  IsChecked="{Binding ActiveMode, Mode=OneWay, Converter={StaticResource ShellModeEqualsConverter}, ConverterParameter=Research}"
                                  ToolTip.Tip="Research docs and AI chat" />
                    <ToggleButton Classes="nav-mode"
                                  Content="PLAN"
                                  Command="{Binding SelectPlanCommand}"
                                  IsChecked="{Binding ActiveMode, Mode=OneWay, Converter={StaticResource ShellModeEqualsConverter}, ConverterParameter=Plan}"
                                  ToolTip.Tip="Corkboard planning board" />
                    <ToggleButton Classes="nav-mode"
                                  Content="WRITE"
                                  Command="{Binding SelectWriteCommand}"
                                  IsChecked="{Binding ActiveMode, Mode=OneWay, Converter={StaticResource ShellModeEqualsConverter}, ConverterParameter=Write}" />
                    <ToggleButton Classes="nav-mode"
                                  Content="MANAGE"
                                  Command="{Binding SelectManageCommand}"
                                  IsChecked="{Binding ActiveMode, Mode=OneWay, Converter={StaticResource ShellModeEqualsConverter}, ConverterParameter=Manage}" />
                    <ToggleButton Classes="nav-mode"
                                  Content="EDIT"
                                  IsEnabled="False"
                                  IsChecked="{Binding ActiveMode, Mode=OneWay, Converter={StaticResource ShellModeEqualsConverter}, ConverterParameter=Edit}"
                                  ToolTip.Tip="Reserved for later" />
                </StackPanel>

                <!-- Right-side toolbar: Git sync pill (workspace-only) + AI chat (workspace-only) + Settings (always visible) -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,4,0"
                            Spacing="4">

                    <!-- Git sync pill — only when a workspace is open and git panel is visible -->
                    <Border Padding="12,6"
                            Margin="0,0,4,0"
                            CornerRadius="10"
                            Background="{DynamicResource SurfaceHighBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            IsVisible="{Binding GitPanelViewModel.IsVisible}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="6"
                                        ToolTip.Tip="{Binding GitPanelViewModel.ChangeSummaryText}">
                                <TextBlock Text="Changes"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           LetterSpacing="0.5"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="↓"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                    <TextBlock Text="{Binding GitPanelViewModel.BehindRemoteCount}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="↑"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                    <TextBlock Text="{Binding GitPanelViewModel.OutgoingCount}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Button Content="{Binding GitPanelViewModel.PrimaryActionText}"
                                    Click="SyncButton_Click"
                                    IsEnabled="{Binding GitPanelViewModel.CanSync}"
                                    Padding="18,6"
                                    CornerRadius="6"
                                    Background="{DynamicResource SynthwavePurpleBrush}"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    ToolTip.Tip="Sync local changes, or pull when already up to date" />
                        </StackPanel>
                    </Border>

                    <!-- Settings — always visible -->
                    <Button Classes="nav-icon"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip.Tip="Settings (Ctrl+,)">
                        <Path Data="M12 15.5A3.5 3.5 0 018.5 12 3.5 3.5 0 0112 8.5a3.5 3.5 0 013.5 3.5 3.5 3.5 0 01-3.5 3.5m7.43-2.92c.04-.32.07-.64.07-.97s-.03-.66-.07-1l2.16-1.63c.19-.15.24-.42.12-.64l-2.05-3.55c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22L2.74 8.87c-.12.21-.08.49.12.64L5.02 11.1c-.04.34-.07.67-.07 1s.03.65.07.97l-2.16 1.66c-.19.15-.24.42-.12.64l2.05 3.55c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2.05-3.55c.12-.22.07-.49-.12-.64l-2.16-1.66z"
                              Fill="{DynamicResource OnSurfaceDimBrush}"
                              Width="18" Height="18"
                              Stretch="Uniform" />
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Synthwave accent stripe (Row 1 — below the menu/tab bar) -->
        <Border Grid.Row="1"
                Height="3"
                BoxShadow="0 2 12 1 #AA9D4EDD, 0 4 28 0 #559D4EDD">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#9D4EDD" Offset="0" />
                    <GradientStop Color="#E91E8C" Offset="0.5" />
                    <GradientStop Color="#38BDF8" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main shell (Row 2) -->
        <Panel Grid.Row="2">

            <!-- Synthwave gradient background (full main area) -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#0B0820" Offset="0" />
                        <GradientStop Color="#0F082A" Offset="0.55" />
                        <GradientStop Color="#160833" Offset="0.82" />
                        <GradientStop Color="#1B0838" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Faint synthwave horizon glow at bottom -->
            <Border VerticalAlignment="Bottom" Height="220" Opacity="0.45">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                        <GradientStop Color="#60E91E8C" Offset="0" />
                        <GradientStop Color="#289D4EDD" Offset="0.38" />
                        <GradientStop Color="#0038BDF8" Offset="0.7" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Layout: [left pane] [editor] [splitter] [right pane] — Write mode only -->
            <Grid x:Name="ShellGrid"
                  ColumnDefinitions="220,4,*,4,280"
                  IsVisible="{Binding IsEditorVisible}">

                <!-- ── LEFT PANE ─────────────────────────────────────────────── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,1,0"
                        MinWidth="48">
                    <Panel>

                        <!-- COLLAPSED: 48px icon rail — visible when neither content area is open -->
                        <StackPanel Width="48"
                                    IsVisible="{Binding !IsAnyLeftPaneOpen}"
                                    Margin="0,8,0,0">
                            <Button Classes="nav-icon"
                                    Command="{Binding WorkspaceViewModel.ToggleChaptersPaneCommand}"
                                    ToolTip.Tip="Chapters (Ctrl+B)">
                                <Path Data="M3 12h18M3 6h18M3 18h18"
                                      Stroke="{DynamicResource OnSurfaceDimBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineCap="Round"
                                      Width="18" Height="18"
                                      Stretch="Uniform" />
                            </Button>
                            <Button Classes="nav-icon"
                                    Command="{Binding SupplementalDocsViewModel.ToggleCommand}"
                                    ToolTip.Tip="Supplemental docs">
                                <Path Data="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8"
                                      Stroke="{DynamicResource OnSurfaceDimBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineCap="Round"
                                      Width="18" Height="18"
                                      Stretch="Uniform" />
                            </Button>
                        </StackPanel>

                        <!-- EXPANDED: Outlook-style explorer bar.
                             Both section headers are ALWAYS visible when the pane is expanded.
                             Each section's content area collapses independently.
                             When both content areas are collapsed, IsAnyLeftPaneOpen → false
                             and the icon rail above takes over.

                             Outer rows: Chapters section | splitter | Docs section
                             Each section is a nested grid: header (48px) + content (* or 0)
                        -->
                        <Grid IsVisible="{Binding IsAnyLeftPaneOpen}"
                              RowDefinitions="*,Auto,*"
                              x:Name="LeftPaneGrid">

                            <!-- Chapters section -->
                            <Grid Grid.Row="0"
                                  x:Name="LeftChaptersSectionGrid"
                                  RowDefinitions="48,*">
                                <Border Grid.Row="0"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="48,*,Auto">
                                        <Button Grid.Column="0"
                                                Classes="nav-icon"
                                                Command="{Binding WorkspaceViewModel.ToggleChaptersPaneCommand}"
                                                ToolTip.Tip="Chapters (Ctrl+B)">
                                            <Path Data="M3 12h18M3 6h18M3 18h18"
                                                  Stroke="{DynamicResource SynthwavePurpleBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineCap="Round"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="CHAPTERS"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1.5"
                                                   Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                        <Button Grid.Column="2"
                                                x:Name="AddChapterButton"
                                                Content="+"
                                                Margin="0,0,8,0"
                                                Padding="8,2"
                                                MinWidth="28"
                                                MinHeight="24"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Foreground="{DynamicResource SynthwavePurpleBrush}"
                                                ToolTip.Tip="Add chapter or part"
                                                Click="AddChapterButton_Click" />
                                    </Grid>
                                </Border>

                                <views:SidebarView Grid.Row="1"
                                                   x:Name="ChaptersViewContent"
                                                   DataContext="{Binding WorkspaceViewModel}"
                                                   IsVisible="{Binding IsChaptersPaneVisible}" />
                            </Grid>

                            <GridSplitter Grid.Row="1"
                                          Height="4"
                                          ResizeDirection="Rows"
                                          IsVisible="{Binding IsBothLeftPanesOpen}"
                                          Background="{DynamicResource BorderSubtleBrush}" />

                            <!-- Docs section -->
                            <Grid Grid.Row="2"
                                  x:Name="LeftDocsSectionGrid"
                                  RowDefinitions="48,*">
                                <Border Grid.Row="0"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,1,0,1">
                                    <Grid ColumnDefinitions="48,*">
                                        <Button Grid.Column="0"
                                                Classes="nav-icon"
                                                Command="{Binding SupplementalDocsViewModel.ToggleCommand}"
                                                ToolTip.Tip="Supplemental docs">
                                            <Path Data="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8"
                                                  Stroke="{DynamicResource SynthwavePurpleBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineCap="Round"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="DOCS"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1.5"
                                                   Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                    </Grid>
                                </Border>

                                <views:SupplementalDocsView Grid.Row="1"
                                                             x:Name="SupplementalDocsViewContent"
                                                             DataContext="{Binding SupplementalDocsViewModel}"
                                                             IsVisible="{Binding IsVisible}" />
                            </Grid>
                        </Grid>

                    </Panel>
                </Border>

                <!-- ── SPLITTER BETWEEN LEFT PANE AND EDITOR ─────────────── -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              ResizeDirection="Columns"
                              Background="{DynamicResource BorderSubtleBrush}" />

                <!-- ── EDITOR ─────────────────────────────────────── -->
                <DockPanel Grid.Column="2">
                    <Border DockPanel.Dock="Top"
                            IsVisible="{Binding IsEditorChapterBarVisible}">
                        <views:EditorChapterBar DataContext="{Binding WorkspaceViewModel.SelectedNode}" />
                    </Border>
                    <views:EditorView DataContext="{Binding EditorViewModel}"
                                      Background="Transparent" />
                </DockPanel>

                <!-- ── SPLITTER (visible when any right pane is open) ─────────── -->
                <GridSplitter Grid.Column="3"
                              Width="4"
                              ResizeDirection="Columns"
                              Background="{DynamicResource BorderSubtleBrush}" />

                <!-- ── RIGHT PANE ─────────────────────────────────────────────── -->
                <Border Grid.Column="4"
                        Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1,0,0,0">
                    <Panel>

                        <!-- COLLAPSED: 48px icon strip — visible when neither pane is open -->
                        <StackPanel Width="48"
                                    IsVisible="{Binding !IsAnyRightPaneOpen}"
                                    Margin="0,8,0,0">
                            <!-- F3: Chapter Info -->
                            <Button Classes="nav-icon"
                                    Command="{Binding ChapterInfoViewModel.ToggleCommand}"
                                    ToolTip.Tip="Chapter Info (F3)">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                      Fill="{DynamicResource OnSurfaceDimBrush}"
                                      Width="18" Height="18"
                                      Stretch="Uniform" />
                            </Button>
                            <!-- F4: Notes -->
                            <Button Classes="nav-icon"
                                    Command="{Binding NotesViewModel.ToggleCommand}"
                                    ToolTip.Tip="Notes (F4)">
                                <Path Data="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8"
                                      Stroke="{DynamicResource OnSurfaceDimBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineCap="Round"
                                      Width="18" Height="18"
                                      Stretch="Uniform" />
                            </Button>
                            <!-- AI Chat (Ctrl+Shift+A) -->
                            <Button Classes="nav-icon"
                                    Command="{Binding ToggleAiChatCommand}"
                                    ToolTip.Tip="AI Chat (Ctrl+Shift+A)">
                                <Path Data="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                                      Stroke="{DynamicResource OnSurfaceDimBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineCap="Round"
                                      Width="18" Height="18"
                                      Stretch="Uniform" />
                            </Button>
                        </StackPanel>

                        <!-- EXPANDED: Outlook-style explorer bar.
                             Both section headers are ALWAYS visible when the pane is expanded.
                             Each section's content area collapses independently within its DockPanel.
                             When both content areas are collapsed, IsAnyRightPaneOpen → false
                             and the icon rail above takes over.

                             Row 0: DockPanel — Chapter panel header (48px fixed) + Chapter panel content (*)
                             Row 1: GridSplitter (auto; visible when both sections are open)
                             Row 2: DockPanel — Notes header (48px fixed) + Notes content (*)

                             Using DockPanel per section ensures the GridSplitter resizes the two
                             full sections (header + content) rather than a header row directly.
                        -->
                        <Grid IsVisible="{Binding IsAnyRightPaneOpen}"
                              RowDefinitions="*,Auto,*,Auto,*"
                              x:Name="RightPaneGrid">

                            <!-- Row 0: Chapter panel DockPanel (header pinned top + content fills rest) -->
                            <DockPanel Grid.Row="0">
                                <Border DockPanel.Dock="Top"
                                        Height="48"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="48,*">
                                        <Button Grid.Column="0"
                                                Classes="nav-icon"
                                                Command="{Binding ChapterInfoViewModel.ToggleCommand}"
                                                ToolTip.Tip="Chapter Info (F3)">
                                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                                  Fill="{DynamicResource SynthwavePurpleBrush}"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ChapterPanelTitle}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1.5"
                                                   Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                    </Grid>
                                </Border>
                                <ContentControl x:Name="ChapterPanelContentControl"
                                                Content="{Binding ChapterPanelContent}"
                                                IsVisible="{Binding IsChapterPanelOpen}" />
                            </DockPanel>

                            <!-- Row 1: GridSplitter between Info and Notes (visible when both content areas open) -->
                            <GridSplitter Grid.Row="1"
                                          Height="4"
                                          ResizeDirection="Rows"
                                          IsVisible="{Binding IsInfoNotesSplitterVisible}"
                                          Background="{DynamicResource BorderSubtleBrush}" />

                            <!-- Row 2: Notes DockPanel (header pinned top + content fills rest) -->
                            <DockPanel Grid.Row="2">
                                <Border DockPanel.Dock="Top"
                                        Height="48"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,1,0,1">
                                    <Grid ColumnDefinitions="48,*">
                                        <Button Grid.Column="0"
                                                Classes="nav-icon"
                                                Command="{Binding NotesViewModel.ToggleCommand}"
                                                ToolTip.Tip="Notes (F4)">
                                            <Path Data="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8"
                                                  Stroke="{DynamicResource SynthwavePurpleBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineCap="Round"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="NOTES"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1.5"
                                                   Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                    </Grid>
                                </Border>
                                <views:NotesView x:Name="NotesViewContent"
                                                 DataContext="{Binding NotesViewModel}" />
                            </DockPanel>

                            <!-- Row 3: GridSplitter between Notes and AI (visible when both content areas open) -->
                            <GridSplitter Grid.Row="3"
                                          Height="4"
                                          ResizeDirection="Rows"
                                          IsVisible="{Binding IsNotesChatSplitterVisible}"
                                          Background="{DynamicResource BorderSubtleBrush}" />

                            <!-- Row 4: AI Chat DockPanel (header always visible; content collapses) -->
                            <DockPanel Grid.Row="4">
                                <Border DockPanel.Dock="Top"
                                        Height="48"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,1,0,1">
                                    <Grid ColumnDefinitions="48,*,Auto">
                                        <Button Grid.Column="0"
                                                Classes="nav-icon"
                                                Command="{Binding ToggleAiChatCommand}"
                                                ToolTip.Tip="AI Chat (Ctrl+Shift+A)">
                                            <Path Data="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                                                  Stroke="{DynamicResource SynthwavePurpleBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineCap="Round"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="AI CHAT"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1.5"
                                                   Foreground="{DynamicResource OnSurfaceDimBrush}" />
                                        <Button Grid.Column="2"
                                                Classes="nav-icon"
                                                Command="{Binding AiChatViewModel.NewConversationCommand}"
                                                ToolTip.Tip="New conversation"
                                                Margin="0,0,4,0">
                                            <TextBlock Text="+"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource SynthwavePurpleBrush}" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <aiviews:AiChatView x:Name="AiChatViewContent"
                                                    DataContext="{Binding AiChatViewModel}" />
                            </DockPanel>

                        </Grid>

                    </Panel>
                </Border>

            </Grid>

            <!-- Research / Plan / Manage — lazy-loaded via ViewLocator, full width -->
            <ContentControl IsVisible="{Binding !IsEditorVisible}"
                            Content="{Binding SecondaryCentreContent}" />

            <!-- Settings overlay — covers full shell area when IsSettingsOpen -->
            <Border IsVisible="{Binding IsSettingsOpen}"
                    Background="{DynamicResource SurfaceBaseBrush}"
                    ZIndex="100">
                <Grid RowDefinitions="48,*">
                    <!-- Settings header bar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Settings"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnSurfaceBrush}"
                                       VerticalAlignment="Center"
                                       Margin="16,0" />
                            <Button Grid.Column="1"
                                    Classes="nav-icon"
                                    Command="{Binding CloseSettingsCommand}"
                                    ToolTip.Tip="Close settings (Esc)"
                                    Margin="0,0,8,0">
                                <TextBlock Text="✕"
                                           FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceDimBrush}" />
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Settings view -->
                    <ContentControl Grid.Row="1"
                                    Content="{Binding ActiveSettingsViewModel}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                                <views:SettingsView />
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>
                </Grid>
            </Border>

        </Panel>

        <!-- Synthwave accent stripe bottom (Row 3) -->
        <Border Grid.Row="3"
                Height="3"
                BoxShadow="0 -2 12 1 #AA9D4EDD, 0 -4 28 0 #559D4EDD">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#38BDF8" Offset="0" />
                    <GradientStop Color="#E91E8C" Offset="0.5" />
                    <GradientStop Color="#9D4EDD" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Toast-style notifications -->
        <Border Grid.RowSpan="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="16"
                MaxWidth="460"
                IsVisible="{Binding HasBanner}"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid ColumnDefinitions="8,*">
                <Border Background="{DynamicResource SynthwavePurpleBrush}"
                        CornerRadius="12,0,0,12" />
                <StackPanel Grid.Column="1"
                            Margin="14,12"
                            Spacing="4">
                    <TextBlock Text="{Binding BannerTitle}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="{Binding BannerMessage}"
                               Foreground="{DynamicResource OnSurfaceDimBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>

</Window>
