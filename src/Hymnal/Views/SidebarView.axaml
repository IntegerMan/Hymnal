<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:models="using:Hymnal.Core.Models"
             xmlns:conv="using:Hymnal.Views.Converters"
             x:Class="Hymnal.Views.SidebarView"
             x:DataType="vm:WorkspaceViewModel"
             Background="{DynamicResource SurfaceElevatedBrush}">

    <UserControl.Resources>
        <conv:NodeKindToFontWeightConverter x:Key="NodeKindToFontWeightConverter" />
        <conv:NodeKindToMarginConverter x:Key="NodeKindToMarginConverter" />
        <conv:NodeKindToForegroundConverter x:Key="NodeKindToForegroundConverter" />
        <conv:NodeKindIsChapterConverter x:Key="NodeKindIsChapterConverter" />
        <conv:NodeKindIsPartConverter x:Key="NodeKindIsPartConverter" />
        <conv:NodeKindIsChapterAndPresentConverter x:Key="NodeKindIsChapterAndPresentConverter" />
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <conv:BoolNotConverter x:Key="BoolNotConverter" />
        <conv:StatusEqualsConverter x:Key="StatusEqualsConverter" />
        <conv:StatusDotTooltipConverter x:Key="StatusDotTooltipConverter" />
        <conv:NullableIntToStringConverter x:Key="NullableIntToStringConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.status-icon-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.status-icon-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}" />
        </Style>
        <Style Selector="Button.status-icon-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- Empty state: shown when no workspace is loaded -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    IsVisible="{Binding !HasWorkspace}">

            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="{DynamicResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="180"
                       FontSize="11"
                       TextAlignment="Center" />

            <TextBlock Text="No workspace open"
                       Foreground="{DynamicResource OnSurfaceMutedBrush}"
                       HorizontalAlignment="Center"
                       FontSize="12" />

            <Button Content="Open Folder…"
                    Command="{Binding OpenWorkspaceCommand}"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource SynthwavePurpleBrush}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Padding="12,6"
                    CornerRadius="4" />
        </StackPanel>

        <!-- Workspace content: CHAPTERS header + chapter tree -->
        <DockPanel IsVisible="{Binding HasWorkspace}" LastChildFill="True">

            <!-- Book root row (selectable — opens Book.txt in editor) -->
            <Button DockPanel.Dock="Top"
                    Command="{Binding SelectBookCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,6"
                    Margin="4,4,4,0"
                    CornerRadius="4"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Center"
                    Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}" />
                    </Style>
                </Button.Styles>
                <!-- 3-column grid matching the list items so word counts align -->
                <Grid ColumnDefinitions="*,60,30">
                    <TextBlock Grid.Column="0"
                               Text="Book"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <ToolTip.Tip>
                            <TextBlock Text="{Binding WorkspaceName}" />
                        </ToolTip.Tip>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalWordCountDisplay}"
                               Foreground="{DynamicResource OnSurfaceMutedBrush}"
                               FontSize="11"
                               TextAlignment="Right"
                               VerticalAlignment="Center">
                        <ToolTip.Tip>
                            <TextBlock Text="{Binding TotalWordCountTooltip}" />
                        </ToolTip.Tip>
                    </TextBlock>
                    <!-- Col 2: spacer matching status button column -->
                </Grid>
            </Button>

            <!-- Chapter tree -->
            <ListBox ItemsSource="{Binding Nodes}"
                     SelectedItem="{Binding SelectedNode}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,4">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="8,5" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
                        <Setter Property="CornerRadius" Value="4" />
                        <Setter Property="Margin" Value="4,1" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
                    </Style>
                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="BorderBrush" Value="{DynamicResource SynthwavePurpleBrush}" />
                        <Setter Property="BorderThickness" Value="2,0,0,0" />
                        <Setter Property="CornerRadius" Value="0,4,4,0" />
                        <Setter Property="Padding" Value="6,5" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:ChapterViewModel">
                        <Grid ColumnDefinitions="*,60,30">

                            <!-- Right-click context menu for Set Target -->
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Mark complete"
                                              IsVisible="{Binding Node.Kind, Converter={StaticResource NodeKindIsChapterConverter}}"
                                              Command="{Binding CompletePhaseCommand}" />
                                    <MenuItem Header="Set Target…"
                                              IsVisible="{Binding Node.Kind, Converter={StaticResource NodeKindIsChapterConverter}}"
                                              Command="{Binding OpenTargetFlyoutCommand}" />
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <!-- Title + proximity fill bar [Col 0] -->
                            <StackPanel Grid.Column="0" Spacing="0">
                                <TextBlock Text="{Binding Node.Title}"
                                           FontWeight="{Binding Node.Kind, Converter={StaticResource NodeKindToFontWeightConverter}}"
                                           Margin="{Binding Node.Kind, Converter={StaticResource NodeKindToMarginConverter}}"
                                           Foreground="{Binding Node.Kind, Converter={StaticResource NodeKindToForegroundConverter}}"
                                           VerticalAlignment="Center" />
                                <!-- Proximity fill bar: visible only when chapter has a target -->
                                <ProgressBar IsVisible="{Binding HasTarget}"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ProximityFill}"
                                             Height="2"
                                             Margin="0,3,4,0"
                                             Background="Transparent"
                                             Foreground="#669D4EDD"
                                             VerticalAlignment="Bottom" />
                            </StackPanel>

                            <!-- Word count / Part total + target popup anchor [Col 1] -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical"
                                        Spacing="0">

                                <!-- Chapter word count (chapter nodes only) -->
                                <TextBlock Text="{Binding WordCountDisplay}"
                                           IsVisible="{Binding Node.Kind, Converter={StaticResource NodeKindIsChapterConverter}}"
                                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                           FontSize="11"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding WordCountTooltip}" />
                                    </ToolTip.Tip>
                                </TextBlock>

                                <!-- Part total (Part nodes only) -->
                                <TextBlock Text="{Binding PartTotalDisplay}"
                                           IsVisible="{Binding Node.Kind, Converter={StaticResource NodeKindIsPartConverter}}"
                                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                           FontSize="11"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding PartTotalTooltip}" />
                                    </ToolTip.Tip>
                                </TextBlock>

                            </StackPanel>

                            <!-- Status button [Col 2] -->
                            <Button Grid.Column="2"
                                    Classes="status-icon-button"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Cursor="Hand">
                                <Button.IsVisible>
                                    <Binding Path="Node.Kind" Converter="{StaticResource NodeKindIsChapterConverter}" />
                                </Button.IsVisible>
                                <ToolTip.Tip>
                                    <MultiBinding Converter="{StaticResource StatusDotTooltipConverter}">
                                        <Binding Path="Node.IsMissing" />
                                        <Binding Path="Status" />
                                    </MultiBinding>
                                </ToolTip.Tip>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Planned"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Planned}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource OrangeBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Outlining"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Outlining}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource OnSurfaceDimBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Drafting"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Drafting}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource CyanBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Editing"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Editing}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource SynthwavePurpleBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Polishing"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Polishing}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource YellowBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Reviewing"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Reviewing}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource PinkBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Done"
                                                  Command="{Binding ChangeStatusCommand}"
                                                  CommandParameter="{x:Static models:ChapterStatus.Done}">
                                            <MenuItem.Icon>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{DynamicResource SuccessBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <Grid Width="22" Height="22">
                                    <Ellipse Width="8" Height="8"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding Node.IsMissing, Converter={StaticResource BoolNotConverter}}"
                                             Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" />
                                    <Path IsVisible="{Binding Node.IsMissing}"
                                          Data="M12 2L2 20h20L12 2zm0 5.5L18.25 18H5.75L12 7.5zm-1 4.5h2v4h-2zm0 5.2h2v2h-2z"
                                          Fill="{DynamicResource OrangeBrush}"
                                          Width="16" Height="16"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Shared target flyout — one Popup for the entire sidebar instead of one per row -->
        <Popup IsOpen="{Binding TargetFlyoutChapter.IsTargetFlyoutOpen, Mode=TwoWay}"
               IsLightDismissEnabled="True"
               Placement="Pointer">
            <Border DataContext="{Binding TargetFlyoutChapter}"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <StackPanel Spacing="8" MinWidth="210">
                    <TextBlock Text="Set word count target"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Min words"
                                   Width="72"
                                   Foreground="{DynamicResource OnSurfaceDimBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBox Text="{Binding PendingMinWords, Converter={StaticResource NullableIntToStringConverter}, Mode=TwoWay}"
                                 Width="90"
                                 Padding="6,3"
                                 FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Max words"
                                   Width="72"
                                   Foreground="{DynamicResource OnSurfaceDimBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBox Text="{Binding PendingMaxWords, Converter={StaticResource NullableIntToStringConverter}, Mode=TwoWay}"
                                 Width="90"
                                 Padding="6,3"
                                 FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Right">
                        <Button Content="Set"
                                Command="{Binding ConfirmTargetCommand}"
                                Background="{DynamicResource SynthwavePurpleBrush}"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Padding="10,4" />
                        <Button Content="Clear"
                                Command="{Binding ClearTargetCommand}"
                                Padding="10,4" />
                        <Button Content="Cancel"
                                Command="{Binding CancelTargetFlyoutCommand}"
                                Padding="10,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="{DynamicResource SurfaceElevatedBrush}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="10">
                <TextBlock Text="Loading…"
                           Foreground="{DynamicResource OnSurfaceDimBrush}"
                           HorizontalAlignment="Center"
                           FontSize="12" />
            </StackPanel>
        </Border>
    </Panel>

</UserControl>
