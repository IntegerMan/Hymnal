<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hymnal.ViewModels"
             xmlns:models="using:Hymnal.Core.Models"
             x:Class="Hymnal.Views.SupplementalDocsView"
             x:DataType="vm:SupplementalDocsViewModel"
             Background="{DynamicResource SurfaceElevatedBrush}">

    <UserControl.Styles>
        <Style Selector="Button.docs-action">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDimBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="Button.docs-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceOverlayBrush}" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHighBrush}" />
        </Style>
    </UserControl.Styles>

    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="6"
                    Margin="8,6,8,4">
            <Button x:Name="CreateDocsFolderButton"
                    Classes="docs-action"
                    Content="+ Folder"
                    ToolTip.Tip="Create a folder under the selected DOCS folder" />
            <Button x:Name="CreateDocsFileButton"
                    Classes="docs-action"
                    Content="+ File"
                    ToolTip.Tip="Create a file under the selected DOCS folder" />
            <Button x:Name="ImportExistingFileButton"
                    Classes="docs-action"
                    Content="+ Existing"
                    ToolTip.Tip="Copy an existing file into the selected DOCS folder" />
        </StackPanel>

        <TreeView x:Name="DocsTree"
                  ItemsSource="{Binding Nodes}"
                  SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                  Background="Transparent"
                  Padding="0,2">
            <TreeView.ItemTemplate>
                <TreeDataTemplate DataType="models:SupplementalDocNode"
                                  ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="18,*" Margin="4,2">
                        <Path Grid.Column="0"
                              Width="12"
                              Height="12"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource OnSurfaceDimBrush}"
                              IsVisible="{Binding IsFolder}"
                              Data="M2 4h7l1.5 2H18v8.5A1.5 1.5 0 0116.5 16h-13A1.5 1.5 0 012 14.5V4z" />
                        <Path Grid.Column="0"
                              Width="11"
                              Height="13"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource CyanBrush}"
                              IsVisible="{Binding IsFile}"
                              Data="M4 2h7l5 5v11a2 2 0 01-2 2H4a2 2 0 01-2-2V4a2 2 0 012-2zm7 1.5V8h4.5" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
